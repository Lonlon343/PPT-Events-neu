{
  "name": "next-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --no-server-fast-refresh",
    "build": "node scripts/patch-loadenv.cjs && yes | tsx scripts/push-schema.ts && tsx scripts/generate-import-map.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "payload:migrate": "tsx ./node_modules/payload/dist/bin/index.js migrate --config src/payload.config.ts",
    "payload:generate": "tsx ./node_modules/payload/dist/bin/index.js generate:types --config src/payload.config.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@payloadcms/db-postgres": "^3.82.1",
    "@payloadcms/db-sqlite": "^3.82.1",
    "@payloadcms/next": "^3.82.1",
    "@payloadcms/richtext-lexical": "^3.82.1",
    "@payloadcms/storage-vercel-blob": "^3.82.1",
    "@react-email/components": "^1.0.12",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.30.3",
    "framer-motion": "^12.38.0",
    "graphql": "^16.13.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "payload": "^3.82.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.11.0",
    "shadcn": "^4.2.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
